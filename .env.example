# 应用服务端口（可选）
PORT=3000

# 前端 API 地址（前后端分离时填写，例如 https://api.xxx.com；同域部署可留空）
VITE_API_BASE_URL=

# 报告解锁码（前端输入后由后端校验）
ACCESS_CODE=XHS001

# DeepSeek / OpenAI 兼容接口密钥
AI_API_KEY=your_api_key_here

# 接口基础地址（DeepSeek默认值，可替换兼容网关）
AI_BASE_URL=https://api.deepseek.com

# 模型名称（按你的服务商可替换）
AI_MODEL=deepseek-chat

# 允许跨域来源（多个逗号分隔），例如 https://xxx.vercel.app,https://career.xxx.com
CORS_ORIGIN=

# API 限流配置（默认每60秒最多30次）
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
